{
  "name": "@happy-nut/monacori",
  "version": "0.1.20",
  "description": "Validation control plane for AI-generated code changes.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happy-nut/monacori.git"
  },
  "bugs": {
    "url": "https://github.com/happy-nut/monacori/issues"
  },
  "homepage": "https://github.com/happy-nut/monacori#readme",
  "bin": {
    "monacori": "bin/monacori.js",
    "mo": "bin/monacori.js"
  },
  "files": [
    "bin",
    "dist",
    "assets",
    "scripts/patch-electron-name.mjs",
    "scripts/fix-pty-spawn-helper.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-viewer-assets.mjs",
    "dev": "npm run build && MONACORI_DEV=1 node bin/monacori.js --foreground",
    "icon": "node scripts/gen-icon.mjs",
    "postinstall": "node scripts/patch-electron-name.mjs && node scripts/fix-pty-spawn-helper.mjs",
    "prepare": "npm run build",
    "smoke": "npm run build && node dist/cli.js --help",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs"
  },
  "keywords": [
    "ai",
    "code-review",
    "diff",
    "testing",
    "verification"
  ],
  "author": "happy-nut <happynut.dev@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.21",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "electron": "^42.4.1",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0"
  }
}
